{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AlgerClipboard",
  "version": "1.0.0",
  "identifier": "com.alger.clipboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "AlgerClipboard",
        "width": 420,
        "height": 480,
        "minWidth": 320,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
