{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AlgerClipboard",
  "version": "1.6.1",
  "identifier": "com.alger.clipboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1REFDMjE5NTFBRDJDMDcKUldRSExLMVJHY0xhTlJvM21GcjhHaEl0RGRoUlNWbm1jUkRwQnYyY2EvNEJ6Rm1tU2VjeThmZlgK",
      "endpoints": [
        "https://github.com/algerkong/AlgerClipboard/releases/latest/download/latest.json"
      ]
    }
  }
}
